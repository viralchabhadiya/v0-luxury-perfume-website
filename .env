APP_NAME="Patel Perfumes"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=/vercel/share/v0-project/database/patel_perfumes.db
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_DRIVER=file

QUEUE_CONNECTION=sync

MAIL_MAILER=log

# ===== EMAIL CONFIGURATION =====
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=noreply@patelperfumes.com
MAIL_FROM_NAME="Patel Perfumes"
MAIL_ENCRYPTION=tls

# SendGrid Alternative
SENDGRID_API_KEY=

# Mailgun Alternative
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ===== SMS CONFIGURATION =====
SMS_DRIVER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_ENABLED=false

AWS_SNS_KEY=
AWS_SNS_SECRET=
AWS_REGION=us-east-1
AWS_SNS_ENABLED=false

# ===== WHATSAPP BUSINESS API =====
WHATSAPP_DRIVER=meta
WHATSAPP_API_VERSION=v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_ENABLED=false

# ===== TELEGRAM BOT =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_ENABLED=false

# ===== PUSH NOTIFICATIONS (FCM) =====
FCM_KEY=
FCM_SENDER_ID=
PUSH_NOTIFICATIONS_ENABLED=false

# ===== AI PROVIDERS =====
AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_ENABLED=false

# Groq Configuration (Fast & Affordable)
GROQ_API_KEY=
GROQ_MODEL=mixtral-8x7b
GROQ_ENABLED=false

# HuggingFace Configuration
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=gpt2
HUGGINGFACE_ENABLED=false

# ===== AI FEATURES =====
AI_RECOMMENDATIONS=true
AI_CHATBOT=true
AI_SEARCH=true
AI_CONTENT_GENERATION=true
AI_SENTIMENT_ANALYSIS=true

# ===== NOTIFICATION DEFAULTS =====
SMS_FOR_ORDERS=true
SMS_FOR_SHIPMENTS=true
WHATSAPP_FOR_SUPPORT=true
TELEGRAM_FOR_ALERTS=true
QUEUE_MAIL=false
